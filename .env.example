# ============================================
# PLAGIATTRACKER - Configuration Environnement
# ============================================

# ============================================
# DATABASE
# ============================================
DB_PASSWORD=your_secure_postgres_password_here
DATABASE_URL=postgresql://plagiat_user:your_secure_postgres_password_here@postgres:5432/plagiattracker

# ============================================
# REDIS
# ============================================
REDIS_PASSWORD=your_secure_redis_password_here
REDIS_URL=redis://:your_secure_redis_password_here@redis:6379/0

# ============================================
# APPLICATION
# ============================================
SECRET_KEY=your_super_secret_key_min_32_characters_long
ENVIRONMENT=development
DEBUG=true
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ============================================
# CONTACT & SUPPORT
# ============================================
SUPPORT_EMAIL=checkone076@gmail.com
PARTNER_PHONE=+237690895735

# ============================================
# ACADEMIC APIs (Optional - can be set by users in app)
# ============================================
SEMANTIC_SCHOLAR_API_KEY=
PUBMED_API_KEY=

# ============================================
# AI CORRECTION APIs (Optional - user-provided)
# ============================================
GROQ_API_KEY=
CLAUDE_API_KEY=

# ============================================
# HUGGING FACE (for local models)
# ============================================
HF_HOME=/app/models
TRANSFORMERS_CACHE=/app/models

# ============================================
# FRONTEND
# ============================================
VITE_API_URL=http://localhost:8000
VITE_SUPPORT_EMAIL=checkone076@gmail.com
VITE_PARTNER_PHONE=+237690895735

# ============================================
# MINIO (Object Storage - Optional)
# ============================================
# MINIO_ROOT_USER=minioadmin
# MINIO_ROOT_PASSWORD=minioadmin
# MINIO_ENDPOINT=minio:9000
# MINIO_BUCKET=plagiat-documents

# ============================================
# SUPABASE (if using cloud PostgreSQL)
# ============================================
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY=your_supabase_anon_key
# SUPABASE_SERVICE_KEY=your_supabase_service_key

# ============================================
# UPSTASH REDIS (if using cloud Redis)
# ============================================
# UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# ============================================
# DEPLOYMENT
# ============================================
# PORT=8000
# HOST=0.0.0.0
# WORKERS=4

# ============================================
# MONITORING (Optional)
# ============================================
# SENTRY_DSN=
# LOG_LEVEL=INFO

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_PER_MINUTE=10
RATE_LIMIT_PER_DAY=100

# ============================================
# FILE UPLOAD
# ============================================
MAX_UPLOAD_SIZE_MB=50
ALLOWED_EXTENSIONS=pdf,docx,txt
UPLOAD_DIR=/app/uploads

# ============================================
# ACTIVATION CODES
# ============================================
CODE_EXPIRY_DAYS_TRIAL=7
CODE_EXPIRY_DAYS_PAID=30
CODE_EXPIRY_DAYS_INSTITUTION=365
